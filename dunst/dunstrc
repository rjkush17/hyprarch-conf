[global]
[global]
monitor = 0
follow = none
width = (200, 400)
height = 100
origin = top-center
offset = 0x20
scale = 0
notification_limit = 3
padding = 10
horizontal_padding = 10
frame_width = 0
corner_radius = 10
font = JetBrains Mono 10
format = "<b>%s</b>\n%b"
alignment = center
vertical_alignment = center
word_wrap = true
ellipsize = middle
icon_position = left
min_icon_size = 32
max_icon_size = 38
transparency = 5
separator_height = 0
separator_color = frame
markup = full
allow_markup = yes
show_age_threshold = 60
stack_duplicates = true
hide_duplicate_count = false
show_indicators = yes
history_length = 20
dmenu = dmenu -p dunst:
browser = xdg-open
always_run_script = true
title = Dunst
class = Dunst
startup_notification = false
verbosity = mesg
corner_radius = 10

[urgency_low]
background = "#16153c"
foreground = "#5C8FBC"
frame_color = "#3687BF"
timeout = 5

[urgency_normal]
background = "#16153c"
foreground = "#5C8FBC"
frame_color = "#3687BF"
timeout = 5

[urgency_critical]
background = "#16153c"
foreground = "#5C8FBC"
frame_color = "#3687BF"
timeout = 10
