{
  "custom/arch": {
    "format": "\uf359",
    "tooltip": true,
    "tooltip-format": "Menu",
    "on-click": "rofi -show drun"
  },
"custom/clip": {
    "format": "´ü┐",
    "tooltip": true,
    "tooltip-format": "Menu",
    "on-click": "~/.config/Script/clipboard.sh"
  },
  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "warp-on-scroll": false,
    "format": "{icon}", // ÔåÉ Yeh line change karni hai!
    "format-icons": {
      "1": "I",
      "2": "II",
      "3": "III",
      "4": "IV",
      "5": "V",
      "6": "VI",
      "7": "VII",
      "8": "VIII",
      "9": "IX",
      "10": "X"
    }
  },

  "pulseaudio": {
    "format": "{icon}   {volume}%",
    "format-bluetooth": "{icon} {volume}% {format_source}",
    "format-bluetooth-muted": "´Ü® {icon} {format_source}",
    "format-muted": "´Ü®  0%",
    "format-source": "´ä░ {volume}%",
    "format-source-muted": "´ä▒",
    "format-icons": {
      "headphone": "´ÇÑ",
      "hands-free": "´ûÉ",
      "headset": "´ûÉ",
      "phone": "´éò",
      "portable": "´éò",
      "car": "´å╣",
      "default": ["´Çª", "´Çº", "´Ç¿"]
    },
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
  },

  "network": {
    "format-wifi": "´ç½    {signalStrength}%", // Corrected Wi-Fi icon
    "format-ethernet": "¾░êÇ {ipaddr}/{cidr}", // Corrected Ethernet icon
    "tooltip-format": "{}", // Corrected Ethernet tooltip icon
    "format-linked": "{ifname} (No IP) ¾░îÿ", // Corrected No IP icon
    "format-disconnected": " ¾░û¬ ", // Corrected Disconnected icon
    "on-click": "kitty --class floating_kitty sh -c 'cat ~/.cache/wal/sequences; nmtui'"
  },
  "bluetooth": {
    "format": "{icon}", // Only the icon
    "format-icons": {
      "enabled": " ¾░é░ ", // Bigger Bluetooth ON
      "disabled": " ¾░é▓ ", // Bigger Bluetooth OFF
      "connected": " ¾░é▒ " // Bigger Bluetooth Connected
    },
    "tooltip": false,
    "exec": "bluetoothctl show | grep -q 'Powered: yes' && echo 'enabled' || echo 'disabled'",
    "interval": 2,
    "on-click": "blueman-manager"
  },
  "cpu": {
    "format": "\uf4bc  {usage}%",
    "tooltip": true
  },
  "memory": {
    "format": "´âë  {}%",
    "tooltip": true
  },
  "temperature": {
    "interval": 10,
    "hwmon-path": "/sys/devices/platform/coretemp.0/hwmon/hwmon4/temp1_input",
    "critical-threshold": 100,
    "format-critical": "¯╝¬  {temperatureC}",
    "format": "¯╝¬  {temperatureC}┬░C"
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-full": "{icon} {capacity}%",
    "format-charging": "¯║í  {capacity}%",
    "format-plugged": "´çª  {capacity}%",
    "format-alt": "{time}  {icon}",
    "format-icons": ["¾░ü║", "¾░ü╝", "¾░ü¥", "¾░ü┐", "¾░ü╣"]
  },
  "battery#bat2": {
    "bat": "BAT2"
  },
  "clock": {
    "format": "{:%H:%MÔöâ%A,%e %B %Y}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "on-click": "gnome-calendar"
  },
  "custom/wlogout": {
    "format": "ÔÅ╗",
    "tooltip": true,
    "tooltip-format": "left-click - session screen\nRight click - Screenlock",
    "on-click": "wlogout -b 6",
    "on-click-right": "hyprlock"
  },
  "taskbar": {
    "on-click": "activate",
    "tooltip": false,
    "format": "{icon} {workspaces}",
    "group-by": "workspaces"
  },
  "tray": {
    "icon-size": 25,
    "spacing": 4
  },

  "wlr/taskbar": {
    "icon-size": 25,
    "spacing": 0,
    "tooltip": true,
    "on-click": "activate",
    "on-click-right": "close",
    "on-scroll-up": "activate-previous",
    "on-scroll-down": "activate-next"
  }
}
