{
  "custom/arch": {
    "format": "≤░μΘ",
    "tooltip": true,
    "tooltip-format": "Menu",
    "on-click": "rofi -show drun"
  },
  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "warp-on-scroll": false,
    "format": "{name}",
    "format-icons": {
      "urgent": "ΎΒς",
      "active": "ΎΗΤ",
      "default": "ΎΕΣ"
    }
  },
  "pulseaudio": {
    "format": "{icon}   {volume}%",
    "format-bluetooth": "{icon} {volume}% ΎΛΦ {format_source}",
    "format-bluetooth-muted": "Ύγσ {icon}ΎΛΦ {format_source}",
    "format-muted": "Ύγσ",
    "format-source": "ΎΕ░ {volume}%",
    "format-source-muted": "ΎΕ▒",
    "format-icons": {
      "headphone": "ΎΑξ",
      "hands-free": "ΎΨΡ",
      "headset": "ΎΨΡ",
      "phone": "ΎΓΧ",
      "portable": "ΎΓΧ",
      "car": "ΎΗ╣",
      "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
    },
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
  },

  "network": {
    "format-wifi": "ΎΘτ ", // Corrected Wi-Fi icon
    "format-ethernet": "≤░ΙΑ {ipaddr}/{cidr}", // Corrected Ethernet icon
    "tooltip-format": "{ifname} via {gwaddr} ≤░ΙΑ", // Corrected Ethernet tooltip icon
    "format-linked": "{ifname} (No IP) ≤░Να", // Corrected No IP icon
    "format-disconnected": "Ύςσ", // Corrected Disconnected icon
    "on-click": "kitty --class floating_kitty sh -c 'cat ~/.cache/wal/sequences; nmtui'"
  },
  "bluetooth": {
    "format": "{icon}", // Only the icon
    "format-icons": {
      "enabled": " ≤░Γ░ ", // Bigger Bluetooth ON
      "disabled": "≤░Γ▓", // Bigger Bluetooth OFF
      "connected": "≤░Γ▒ " // Bigger Bluetooth Connected
    },
    "tooltip": false,
    "exec": "bluetoothctl show | grep -q 'Powered: yes' && echo 'enabled' || echo 'disabled'",
    "interval": 2,
    "on-click": "blueman-manager"
  },
  "cpu": {
    "format": "ΎΜδ  {usage}%",
    "tooltip": true
  },
  "memory": {
    "format": "ΎΔΚ  {}%",
    "tooltip": true
  },
  "temperature": {
    "interval": 10,
    "hwmon-path": "/sys/devices/platform/coretemp.0/hwmon/hwmon4/temp1_input",
    "critical-threshold": 100,
    "format-critical": "ΎΜΘ {temperatureC}",
    "format": "ΎΜΚ {temperatureC}┬░C"
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}  {capacity}%",
    "format-full": "{icon}  {capacity}%",
    "format-charging": "ΎΩπ  {capacity}%",
    "format-plugged": "ΎΘο  {capacity}%",
    "format-alt": "{time}  {icon}",
    "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
  },
  "battery#bat2": {
    "bat": "BAT2"
  },
  "clock": {
    "format": "{:%H:%M | %e %B}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": "{:%H:%M | %e %B}"
  },
  "custom/wlogout": {
    "format": "έΠ╗",
    "tooltip": false,
    "on-click": "wlogout -b 6"
  },
"taskbar": {
    "on-click": "activate",
    "tooltip": false,
    "format": "{icon} {title}"
}  
}
