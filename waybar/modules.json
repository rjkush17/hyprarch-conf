{
  "custom/arch": {
    "format": "\uf359",
    "tooltip": true,
    "tooltip-format": "Menu",
    "on-click": "rofi -show drun"
  },

  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "warp-on-scroll": false,
    "format": "{icon}", // έΗΡ Yeh line change karni hai!
    "format-icons": {
      "1": "I",
      "2": "II",
      "3": "III",
      "4": "IV",
      "5": "V",
      "6": "VI",
      "7": "VII",
      "8": "VIII",
      "9": "IX",
      "10": "X"
    }
  },

  "pulseaudio": {
    "format": "{icon}   {volume}%",
    "format-bluetooth": "{icon} {volume}% {format_source}",
    "format-bluetooth-muted": "Ύγσ {icon} {format_source}",
    "format-muted": "Ύγσ  0%",
    "format-source": "ΎΕ░ {volume}%",
    "format-source-muted": "ΎΕ▒",
    "format-icons": {
      "headphone": "ΎΑξ",
      "hands-free": "ΎΨΡ",
      "headset": "ΎΨΡ",
      "phone": "ΎΓΧ",
      "portable": "ΎΓΧ",
      "car": "ΎΗ╣",
      "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
    },
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
  },

  "network": {
    "format-wifi": "ΎΘτ    {signalStrength}%", // Corrected Wi-Fi icon
    "format-ethernet": "≤░ΙΑ {ipaddr}/{cidr}", // Corrected Ethernet icon
    "tooltip-format": "{}", // Corrected Ethernet tooltip icon
    "format-linked": "{ifname} (No IP) ≤░Να", // Corrected No IP icon
    "format-disconnected": " ≤░Ψς ", // Corrected Disconnected icon
    "on-click": "kitty --class floating_kitty sh -c 'cat ~/.cache/wal/sequences; nmtui'"
  },
  "bluetooth": {
    "format": "{icon}", // Only the icon
    "format-icons": {
      "enabled": " ≤░Γ░ ", // Bigger Bluetooth ON
      "disabled": " ≤░Γ▓ ", // Bigger Bluetooth OFF
      "connected": " ≤░Γ▒ " // Bigger Bluetooth Connected
    },
    "tooltip": false,
    "exec": "bluetoothctl show | grep -q 'Powered: yes' && echo 'enabled' || echo 'disabled'",
    "interval": 2,
    "on-click": "blueman-manager"
  },
  "cpu": {
    "format": "\uf4bc  {usage}%",
    "tooltip": true
  },
  "memory": {
    "format": "ΎΔΚ  {}%",
    "tooltip": true
  },
  "temperature": {
    "interval": 10,
    "hwmon-path": "/sys/devices/platform/coretemp.0/hwmon/hwmon4/temp1_input",
    "critical-threshold": 100,
    "format-critical": "Ό╝ς  {temperatureC}",
    "format": "Ό╝ς  {temperatureC}┬░C"
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-full": "{icon} {capacity}%",
    "format-charging": "Ό║κ  {capacity}%",
    "format-plugged": "ΎΘο  {capacity}%",
    "format-alt": "{time}  {icon}",
    "format-icons": ["≤░Β║", "≤░Β╝", "≤░Β╛", "≤░Β┐", "≤░Β╣"]
  },
  "battery#bat2": {
    "bat": "BAT2"
  },
  "clock": {
    "format": "{:%H:%MέΦΔ%A,%e %B %Y}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": "{:%H:%M | %e %B}"
  },
  "custom/wlogout": {
    "format": "έΠ╗",
    "tooltip": true,
    "tooltip-format": "left-click - session screen\nRight click - Screenlock",
    "on-click": "wlogout -b 6",
    "on-click-right": "hyprlock"
  },
  "taskbar": {
    "on-click": "activate",
    "tooltip": false,
    "format": "{icon} {workspaces}",
    "group-by": "workspaces"
  },
  "tray": {
    "icon-size": 25,
    "spacing": 4
  },

  "wlr/taskbar": {
    "icon-size": 25,
    "spacing": 0,
    "tooltip": true,
    "on-click": "activate",
    "on-click-right": "close",
    "on-scroll-up": "activate-previous",
    "on-scroll-down": "activate-next"
  }
}
